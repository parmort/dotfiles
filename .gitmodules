# vim: noexpandtab :

[submodule "zsh/fsh"]
	path = zsh/.config/zsh/plugs/fsh
	url = https://github.com/zdharma/fast-syntax-highlighting
[submodule "zsh/zsh-autosuggestions"]
	path = zsh/.config/zsh/plugs/zsh-autosuggestions
	url = https://github.com/zsh-users/zsh-autosuggestions
[submodule "bspwm/swallow"]
	path = bspwm/.config/bspwm/swallow
	url = https://github.com/JopStro/bspswallow.git
[submodule "zsh/.config/zsh/plugs/spaceship-prompt"]
	path = zsh/.config/zsh/plugs/spaceship-prompt
	url = https://github.com/spaceship-prompt/spaceship-prompt
[submodule "tmux/.config/tmux/plugins/tpm"]
	path = tmux/.config/tmux/plugins/tpm
	url = https://github.com/tmux-plugins/tpm
[submodule "zsh/.config/zsh/plugs/fast-syntax-highlighting"]
	path = zsh/.config/zsh/plugs/fast-syntax-highlighting
	url = https://github.com/zdharma-continuum/fast-syntax-highlighting
[submodule "bspwm/.config/bspwm/catppuccin-polybar"]
	path = bspwm/.config/bspwm/catppuccin-polybar
	url = https://github.com/catppuccin/polybar
